DATABASE_URL=postgresql://user:password@localhost:5432/timecrunch
# Set to false for a local Postgres server without TLS. Leave true/blank for Neon/Render.
DATABASE_SSL=false
JWT_SECRET=change_this_to_a_long_random_string
PORT=3001
APP_URL=https://your-domain.com

# Cloudflare R2 media storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=info@opsfloa.com
EMAIL_FROM=info@opsfloa.com
SENDGRID_WEBHOOK_SECRET=
TRIAL_DAYS=14
TRIAL_LIMIT_PER_IP=5

# Optional integrations
QBO_CLIENT_ID=
QBO_REDIRECT_URI=
QBO_ENCRYPTION_KEY=
QBO_ENVIRONMENT=sandbox
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_BUSINESS_BASE=
STRIPE_PRICE_BUSINESS_BASE_ANNUAL=
STRIPE_PRICE_BUSINESS_WORKER=
STRIPE_PRICE_BUSINESS_WORKER_ANNUAL=
STRIPE_PRICE_QBO=
STRIPE_PRICE_QBO_ANNUAL=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
LOG_LEVEL=info
WHITELISTED_IPS=

# Optional demo data seed target. The seed script only runs when called manually:
#   npm run seed:demo
DEMO_COMPANY_NAME=Demo Operations
# Set to true only in dev/stage env vars when you want npm start/deploy migrations
# to fill the fictional company automatically after schema migrations.
DEMO_SEED_AUTO=true
DEMO_ADMIN_USERNAME=Admin
DEMO_ADMIN_PASSWORD=Admin123

# Email behaviour in non-production environments (ignored when NODE_ENV=production):
#   redirect  — send to EMAIL_REDIRECT_TO with original recipient noted in subject (default)
#   suppress  — log only, do not send
#   real      — send to the real recipient (use with caution on staging)
EMAIL_MODE=redirect
EMAIL_REDIRECT_TO=info@opsfloa.com
