{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -File \"C:\\Users\\v-normand\\Workspaces\\TimeCrunch_Claude\\.claude\\npm-install-hook.ps1\"",
            "statusMessage": "Running npm install...",
            "timeout": 120
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(npm install:*)",
      "Bash(npm.cmd install:*)",
      "Bash(powershell.exe *)"
    ]
  }
}
